* text=auto

# Source
*.cpp       text eol=lf
*.hpp       text eol=lf
*.c         text eol=lf
*.h         text eol=lf
*.inl       text eol=lf
*.cs        text eol=lf
*.py        text eol=lf
*.lua       text eol=lf

# Shaders
*.glsl      text eol=lf
*.hlsl      text eol=lf
*.fx        text eol=lf
*.vert      text eol=lf
*.frag      text eol=lf
*.geom      text eol=lf
*.comp      text eol=lf

*.json      text eol=lf
*.xml       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf
*.txt       text eol=lf
*.md        text eol=lf

# Build systems
Docs/       text
CMakeLists.txt text eol=lf
*.cmake     text eol=lf

# Image formats
*.png       binary
*.jpg       binary
*.jpeg      binary
*.tga       binary
*.bmp       binary
*.dds       binary
*.psd       binary
*.hdr       binary
*.exr       binary
*.ico       binary

# Audio formats
*.wav       binary
*.mp3       binary
*.ogg       binary
*.flac      binary

# Fonts
*.ttf       binary
*.otf       binary

# Compiled binaries / Libraries
*.exe       binary
*.dll       binary
*.so        binary
*.dylib     binary
*.a         binary
*.lib       binary
*.pdb       binary

# 3D Models & Animations
*.fbx       filter=lfs diff=lfs merge=lfs -text
*.obj       filter=lfs diff=lfs merge=lfs -text
*.gltf      filter=lfs diff=lfs merge=lfs -text
*.glb       filter=lfs diff=lfs merge=lfs -text
*.blend     filter=lfs diff=lfs merge=lfs -text
*.max       filter=lfs diff=lfs merge=lfs -text
*.dae       filter=lfs diff=lfs merge=lfs -text

# Video Formats
*.mp4       filter=lfs diff=lfs merge=lfs -text
*.mkv       filter=lfs diff=lfs merge=lfs -text
*.mov       filter=lfs diff=lfs merge=lfs -text